rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Current-session log: one document per dough type, overwritten on each confirm.
    // Shared across the bakery team (any authenticated client reads the same log).
    // NOTE: with Anonymous Auth this means any authenticated client can read it.
    // True per-bakery isolation requires real (non-anonymous) auth — tracked as the
    // next security step; this ruleset only hardens validation, not read scope.
    match /log/{dough} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && dough in ['focaccia', 'brioche', 'sourdough']
        && request.resource.data.keys().hasOnly(['dough', 'date', 'time', 'text'])
        && request.resource.data.dough is string
        && request.resource.data.dough in ['Focaccia', 'Brioche', 'Sourdough']
        && request.resource.data.date is string
        && request.resource.data.date.size() < 50
        && request.resource.data.time is string
        && request.resource.data.time.size() < 10
        && request.resource.data.text is string
        && request.resource.data.text.size() < 2000;

      allow delete: if request.auth != null
        && dough in ['focaccia', 'brioche', 'sourdough'];
    }

    // Daily production log: one document per day (YYYY-MM-DD), keyed by dough type.
    // saveDailyEntry() merges one dough sub-entry at a time, so request.resource.data
    // is the full merged document — its top-level keys must be a subset of the three
    // dough types, and each present sub-entry must be a map. The app never deletes
    // daily logs, so delete is denied.
    match /daily-logs/{date} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.keys().hasOnly(['focaccia', 'brioche', 'sourdough'])
        && request.resource.data.keys().size() > 0
        && (!('focaccia' in request.resource.data) || request.resource.data.focaccia is map)
        && (!('brioche' in request.resource.data) || request.resource.data.brioche is map)
        && (!('sourdough' in request.resource.data) || request.resource.data.sourdough is map);

      allow delete: if false;
    }

    // ── Orders system ─────────────────────────────────────────────────────────
    // New collections for the supplier-order workflow. Every document must carry
    // bakery == 'main' (forward-compatible with future per-bakery isolation).
    // Shared across the team under Anonymous Auth, exactly like log/daily-logs.
    // Field-level validation will tighten per collection as each phase lands.
    match /suppliers/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.bakery == 'main';
      allow delete: if false;
    }

    match /ingredients/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.bakery == 'main';
      allow delete: if false;
    }

    // Drafts are overwritten on every change and cleared once an order is sent,
    // so delete is permitted here (unlike the other collections).
    match /drafts/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.bakery == 'main';
      allow delete: if request.auth != null;
    }

    match /orders-history/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.bakery == 'main';
      allow delete: if false;
    }

    // Calculator configuration: a single shared document (config/calculator)
    // holding the configurable clients, products and per-client unit weights for
    // the dough tabs (+ the market order). Shared across the team under Anonymous
    // Auth, like the log. bakery == 'main' is required on write, as elsewhere.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.bakery == 'main';
      allow delete: if false;
    }

    // Production logs (new model): each log is its own document logs/{id} with an
    // append-only version chain INSIDE the document (see js/log-model.js). Replaces
    // the old one-doc-per-dough `log` collection above (kept for migration reads).
    // Delete is allowed here — unlike history-keeping collections — because the
    // append-only history lives inside the document, so a delete is the user
    // explicitly removing a whole log (confirmed in the UI). Editing only ever
    // appends a version; it never deletes one.
    match /logs/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.bakery == 'main'
        && request.resource.data.dough is string
        && request.resource.data.versions is list;
      allow delete: if request.auth != null;
    }

    // Default deny: any collection not explicitly matched above is locked down,
    // so adding a new collection can never accidentally inherit open access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
